network-timeout=600000
fetch-retries=7
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
prefer-offline=true

# Required for Prisma + Docker: with pnpm's isolated linker (default), `prisma
# generate` writes the client into the pnpm virtual store rather than the
# project-root node_modules/.prisma/ that Dockerfile runner stages COPY from.
# Hoisting flattens node_modules so Prisma's output lands at the expected path.
# See: https://pnpm.io/npmrc#shamefully-hoist
shamefully-hoist=true
