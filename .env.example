# .env.example — TEMPLATE ONLY. Never commit a real .env.
# Copy to .env and fill in real values.
# Fields marked [REQUIRED IN PRODUCTION] cause a hard startup failure
# if absent when NODE_ENV=production.

# ============================================================
# DATABASE — [REQUIRED IN PRODUCTION]
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/seotool"

# ============================================================
# INDEXNOW — Bing, Yandex, Naver bulk indexing
# Generate key: openssl rand -hex 16
# Host file at: https://{INDEXNOW_HOST}/{INDEXNOW_API_KEY}.txt
# File contents: just the key string (no newline)
# ============================================================
INDEXNOW_API_KEY="your-32-char-hex-key"
INDEXNOW_HOST="yourdomain.com"

# ============================================================
# NEXTAUTH — [REQUIRED IN PRODUCTION]
# Generate secret: openssl rand -base64 32
# ============================================================
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32-output"
NEXTAUTH_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ============================================================
# GEMINI — [REQUIRED IN PRODUCTION]
# ============================================================
GEMINI_API_KEY="AIzaSy..."
GEMINI_RPM_LIMIT="4"

# ============================================================
# LIVEKIT — [REQUIRED IN PRODUCTION] (voice agent)
# ============================================================
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="APIxxx..."
LIVEKIT_API_SECRET="xxx..."

# ============================================================
# STRIPE — [REQUIRED IN PRODUCTION]
# Missing = payment webhooks silently fail, tiers never activate.
# Use sk_live_ / pk_live_ / whsec_ in production.
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_AGENCY_PRICE_ID="price_..."
STRIPE_CREDIT_PACK_PRICE_ID="price_..."

# ============================================================
# CRON SECRET — [REQUIRED IN PRODUCTION] (min 32 chars)
# Missing = all 11 cron jobs silently return 401 with no alerting.
# Generate: openssl rand -hex 32
# ============================================================
CRON_SECRET="replace-with-openssl-rand-hex-32-output"

# ============================================================
# INNGEST — [REQUIRED IN PRODUCTION]
# Missing INNGEST_SIGNING_KEY = zero request signature verification
# on /api/inngest — any HTTP client can invoke your background jobs.
# ============================================================
INNGEST_EVENT_KEY="evt_..."
INNGEST_SIGNING_KEY="signkey-prod-..."

# ============================================================
# REDIS (required in production for rate limiting)
# Upstash free tier: https://upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx..."

# Upstash Vector (optional — semantic LLM response cache)
UPSTASH_VECTOR_REST_URL="https://xxx-vector.upstash.io"
UPSTASH_VECTOR_REST_TOKEN="xxx..."

# Legacy ioredis URL — only needed for docker-compose local setup
REDIS_URL="redis://localhost:6379"

# ============================================================
# OAUTH PROVIDERS (at least one needed for social login)
# ============================================================
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
GITHUB_ID="Ov23li..."
GITHUB_SECRET="xxx..."

# ============================================================
# OPTIONAL — features degrade gracefully when absent
# ============================================================

# AI providers for AEO citation checks
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
PERPLEXITY_API_KEY="pplx-..."

# SEO data APIs
PAGESPEED_API_KEY="AIzaSy..."
GOOGLE_SAFE_BROWSING_KEY="AIzaSy..."
GOOGLE_KG_API_KEY="AIzaSy..."
GOOGLE_SEARCH_API_KEY="AIzaSy..."
GOOGLE_SEARCH_CX="your-cx"
SERPER_API_KEY="xxx..."
SERPAPI_KEY="xxx..."

# Backlinks (Moz)
MOZ_API_TOKEN="xxx..."
MOZ_ACCESS_ID="xxx..."
MOZ_SECRET_KEY="xxx..."

# Email (Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_DOMAIN="yourdomain.com"

# Images for blog posts (Unsplash)
UNSPLASH_ACCESS_KEY="xxx..."

# GitHub auto-fix PRs
GITHUB_TOKEN="ghp_..."

# Google Indexing API (service account)
GOOGLE_CLIENT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Blog publishing
HASHNODE_TOKEN=""
HASHNODE_PUBLICATION_ID=""

# Admin email override
ADMIN_EMAIL="admin@yourdomain.com"

# Browserless (JS-rendered crawling)
BROWSERLESS_URL="wss://chrome.browserless.io?token=xxx"

# DataForSEO — real search volume, keyword difficulty, SERP data, domain rank
# Free trial: https://dataforseo.com  (~$0.0005/keyword lookup)
# Set both to unlock: real KD, volume, CPC, SERP feature detection, domain metrics
DATAFORSEO_LOGIN="..."
DATAFORSEO_PASSWORD="..."

# Semrush — best-in-class competitor traffic estimates (optional but recommended)
# Used by getDomainMetrics() to fetch real organic traffic for competitor domains.
# Free: 10 API units/day. Growth plan (~$140/mo): 3,500 units/day.
# Get key: https://developers.semrush.com/api/
SEMRUSH_API_KEY="..."
