{
  "name": "aiseo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.15.1"
  },
  "packageManager": "pnpm@8.15.1",
  "scripts": {
    "dev:next": "next dev",
    "dev": "tsx -r dotenv/config server.ts",
    "demo:build": "npx esbuild livekit-agent.ts --bundle --platform=node --packages=external --outfile=livekit-agent.js",
    "demo": "pnpm run demo:build && concurrently --names 'WEB,AGENT' --prefix-colors 'cyan,magenta' 'tsx server.ts' 'node livekit-agent.js dev'",
    "agent:build": "npx esbuild livekit-agent.ts --bundle --platform=node --packages=external --outfile=livekit-agent.js",
    "agent": "npm run agent:build && node livekit-agent.js dev",
    "agent:dev": "npx esbuild livekit-agent.ts --bundle --platform=node --packages=external --outfile=livekit-agent.js && node livekit-agent.js dev",
    "agent:watch": "node livekit-agent.js dev",
    "agent:start": "npm run agent:build && node livekit-agent.js start",
    "build": "node scripts/generate-og-image.js || true && next build",
    "start:next": "next start",
    "start": "node server.js",
    "start:custom": "NODE_ENV=production tsx server.ts",
    "start:voice": "NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "voice-agent": "tsx livekit-agent.ts dev"
  },
